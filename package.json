{
  "name": "pwd-fs",
  "version": "3.5.5",
  "description": "Path-aware file system utilities with scoped working directories and recursive operations",
  "keywords": [
    "umask",
    "test",
    "stat",
    "chmod",
    "chown",
    "symlink",
    "copy",
    "rename",
    "remove",
    "read",
    "write",
    "readdir",
    "mkdir"
  ],
  "author": {
    "name": "Stanislav Potemkin",
    "email": "woodger@ya.ru"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:woodger/pwd-fs.git"
  },
  "engines": {
    "node": ">=14.18.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "fwa --prune",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@types/node": "20.19.25",
    "eslint": "9.35.0",
    "fwa": "^2.0.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
